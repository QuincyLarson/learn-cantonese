    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "hanzi": "^2.1.5",
    "to-jyutping": "^3.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
